{
  "manifest_version": 3,
  "name": "Copy Paste Pro",
  "version": "1.0",
  "description": "Enable copy paste anywhere",
  "permissions": ["scripting", "activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
